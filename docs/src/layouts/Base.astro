---
// SPDX-License-Identifier: Apache-2.0
import { ClientRouter } from 'astro:transitions'
import { Footer } from '@ifylab/design-system'
import SiteNav from '../components/SiteNav.astro'
import { footerColumns, footerOutputs, footerDescription, copyright } from '../data/site'
import '../styles/global.css'

interface Props {
  title: string
  description?: string
}

const {
  title,
  description = 'growing set of focused agentic tools, built on open source.',
} = Astro.props

const isHome = Astro.url.pathname === '/'
const canonical = new URL(Astro.url.pathname, Astro.site).href
const ogImage = new URL('/media/og/og-light.png', Astro.site).href
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content=".ify" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content=".ify — growing set of focused agentic tools" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <meta name="theme-color" content="#416f6f" />
    {/* Apply the saved theme before first paint, and re-apply after each view-transition
        swap — the swapped-in document otherwise resets data-theme to the SSR default. */}
    <script is:inline>
      ;(function () {
        function applyTheme() {
          try {
            var t = localStorage.getItem('ify-theme')
            if (t === 'light' || t === 'dark') document.documentElement.dataset.theme = t
          } catch (e) {}
        }
        applyTheme()
        if (!window.__ifyThemeBound) {
          window.__ifyThemeBound = true
          document.addEventListener('astro:after-swap', applyTheme)
        }
      })()
    </script>
    <ClientRouter />
  </head>
  <body>
    <SiteNav />
    <main>
      {
        !isHome && (
          <button class="back-arrow" type="button" aria-label="Go back to the previous page">
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M19 12H5" />
              <path d="M12 19l-7-7 7-7" />
            </svg>
            Back
          </button>
        )
      }
      <slot />
    </main>
    <Footer
      description={footerDescription}
      columns={footerColumns}
      outputs={footerOutputs}
      copyright={copyright}
      logoLight="/media/brand/logo-light.png"
      logoDark="/media/brand/logo-dark.png"
    />
  </body>
</html>

<script>
  function initBack() {
    const btn = document.querySelector<HTMLButtonElement>('.back-arrow')
    if (!btn) return
    btn.addEventListener('click', () => {
      if (window.history.length > 1) window.history.back()
      else window.location.href = '/'
    })
  }
  document.addEventListener('astro:page-load', initBack)
</script>
